# Copy this file to .env and add your API key
# cp .env.example .env

OPENAI_API_KEY=sk-your-key-here
# Groq API key (free): https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_your-key-here
STRIPE_WEBHOOK_SECRET=

# App security
SECRET_KEY=your-super-secret-key-change-this-in-production
ADMIN_EMAIL=your-email-here
ADMIN_PASSWORD=your-password-here

# Gmail SMTP (for password reset emails)
GMAIL_EMAIL=your-email-here
GMAIL_APP_PASSWORD=your-key-here
